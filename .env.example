# Production (Cloudflare Pages): leave VITE_API_URL unset — /api is proxied to Render (no CORS).
# VITE_API_URL=

# Call Render API directly (requires backend CORS for your frontend origin):
# VITE_API_URL=https://seshu-backend.onrender.com/api

# Local development: leave unset to use Vite proxy (/api -> localhost:8080)
# VITE_API_PROXY_TARGET=http://localhost:8080
