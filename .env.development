# Local dev uses the Vite proxy (/api -> localhost:8080) when VITE_API_URL is unset.
# Uncomment to call the hosted API directly during development:
# VITE_API_URL=https://seshu-backend.onrender.com/api

# Override the local proxy target if your backend runs elsewhere:
# VITE_API_PROXY_TARGET=http://localhost:8080
